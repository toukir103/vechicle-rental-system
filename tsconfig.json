{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "commonjs",
    "target": "es2019",
    "lib": ["es2019"],
    "types": ["node"],

    /* Interop */
    "esModuleInterop": true,

    /* Other Outputs */
    "sourceMap": true,
    "declaration": false,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}
